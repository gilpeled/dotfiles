{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "google/gemini-3.1-flash-lite-preview",
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-openai-codex-auth@latest"
  ],
  "disabled_providers": [
    "anthropic",
    "opencode",
    "amazon-bedrock"
  ],
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ty": {
      "command": [
        "ty",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi",
        ".ipynb"
      ]
    },
    "ruff": {
      "command": [
        "ruff",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi",
        ".ipynb"
      ]
    }
  },
  "formatter": {
    "ruff": {
      "command": [
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".py",
        ".pyi",
        ".ipynb"
      ]
    },
    "ruff_organize_imports": {
      "command": [
        "ruff",
        "check",
        "--select",
        "I",
        "--fix-only",
        "$FILE"
      ],
      "extensions": [
        ".py",
        ".pyi",
        ".ipynb"
      ]
    }
  },
  "mcp": {
    "mcpretentious": {
      "type": "local",
      "command": [
        "npx",
        "mcpretentious"
      ],
      "enabled": true
    }
  }
}
