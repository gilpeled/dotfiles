{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "google/gemini-3.1-flash-lite-preview",
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-openai-codex-auth@latest"
  ],
  "disabled_providers": [
    "anthropic",
    "opencode",
    "amazon-bedrock"
  ],
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ty": {
      "command": [
        "ty",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "ruff": {
      "command": [
        "ruff",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  },
  "formatter": {
    "ruff": {
      "command": [
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "ruff_organize_imports": {
      "command": [
        "ruff",
        "check",
        "--select",
        "I",
        "--fix-only",
        "$FILE"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/gilpeled"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "docker": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@swartdraak/docker-mcp-server"
      ],
      "enabled": true
    },
    "mcpretentious": {
      "type": "local",
      "command": [
        "npx",
        "mcpretentious"
      ],
      "enabled": true
    }
  }
}
