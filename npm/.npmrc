# Supply-chain mitigation: refuse to install a package version until it has
# been published for at least N days. Most malicious npm releases (Shai-Hulud,
# chalk/debug, ua-parser-js, event-stream, etc.) get caught and unpublished
# within 24–72h, so a multi-day quarantine catches the bulk of acute attacks
# at the cost of slightly stale deps. Layered on top of safe-chain (Aikido)
# in ~/.safe-chain/, which blocks known-bad packages reactively.
#
# To bypass for a single install: npm install --min-release-age=0
#
# pnpm note: pnpm reads its own `minimumReleaseAge` (minutes) from .npmrc,
# but npm warns "Unknown user config" on every command if it's set here.
# Not used in this stack today (Claude Code → npm, opencode → bun), so it's
# left out. If you start using pnpm, add: `minimumReleaseAge=10080`.

# npm 11.5+ — value is in DAYS.
# Internally converts to --before; dist-tags (@latest, etc.) fall back to the
# most recent version that passes the age filter.
min-release-age=7
