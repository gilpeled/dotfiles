{
  "permissions": {
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "skipAutoPermissionPrompt": true,
  "effortLevel": "high",
  "statusLine": {
    "type": "command",
    "command": "sh /Users/gilpeled/.claude/statusline-command.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME\"/.claude/hooks/enforce-uv.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME\"/.claude/hooks/ruff-after-edit.sh"
          }
        ]
      }
    ]
  }
}
